# Copy this file to .env and fill in real secrets. Do NOT commit your real .env to version control.
PORT=3000
JWT_SECRET=replace-me-with-a-long-random-secret
DB_HOST=localhost
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=baroque
ENABLE_AUTOFILL=false

# Optional runtime toggles useful for containerized or Pterodactyl environments
# If true, SKIP_MIGRATIONS avoids running knex migrations at startup
SKIP_MIGRATIONS=false
# If true, START_WITHOUT_DB allows the app to start even when DB/migrations fail
START_WITHOUT_DB=false
# Host to bind the server on (0.0.0.0 for containerized environments)
LISTEN_HOST=0.0.0.0

# OAuth credentials (only if you use Google OAuth)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback

NODE_ENV=development
