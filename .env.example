# Copy this file to .env and fill in real secrets. Do NOT commit your real .env to version control.
PORT=3000
JWT_SECRET=replace-me-with-a-long-random-secret
DB_HOST=localhost
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=baroque
ENABLE_AUTOFILL=false

# Optional runtime toggles useful for containerized or Pterodactyl environments
# If true, SKIP_MIGRATIONS avoids running knex migrations at startup
SKIP_MIGRATIONS=false
# If true, START_WITHOUT_DB allows the app to start even when DB/migrations fail
START_WITHOUT_DB=false
# Host to bind the server on (0.0.0.0 for containerized environments)
LISTEN_HOST=0.0.0.0

# OAuth credentials (only if you use Google OAuth)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback

NODE_ENV=development

# --- Start script / Auto-update variables (used by start.sh) ---
GIT_ADDRESS=
# Branch to clone / reset from when AUTO_UPDATE=1
BRANCH=main
# If set to "1", startup will fetch and reset to origin/$BRANCH on boot
AUTO_UPDATE=0
# Space-separated package names to install before starting (optional)
NODE_PACKAGES=
# Space-separated packages to uninstall before starting (optional)
UNNODE_PACKAGES=
# If provided, the startup script will run this file instead of the default API+worker
MAIN_FILE=
# Extra args passed when running MAIN_FILE
NODE_ARGS=

# --- Worker / queue tuning ---
DUP_QUEUE_POLL_MS=30000
# (not recommended for production if scans are CPU-heavy)
RUN_DUP_QUEUE_INLINE=false

