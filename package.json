{
  "name": "baroque-api",
  "version": "1.0.0",
  "description": "",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "start": "node ./src/server.js",
    "start:prod": "NODE_ENV=production node ./src/server.js",
    "dev": "nodemon --watch src --exec node ./src/server.js",
    "worker": "node ./src/worker/dupWorker.js",
    "migrate": "npx knex migrate:latest --knexfile ./knexfile.cjs",
    "migrate:rollback": "npx knex migrate:rollback --knexfile ./knexfile.cjs",
    "test": "jest",
    "test:ci": "jest --runInBand --detectOpenHandles --forceExit"
  },
  "private": true,
  "dependencies": {
    "axios": "^1.13.6",
    "bcrypt": "^6.0.0",
    "cheerio": "^1.2.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "googleapis": "^171.4.0",
    "jsonwebtoken": "^9.0.3",
    "knex": "^3.1.0",
    "mysql2": "^3.20.0",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "jest": "^29.6.1",
    "nodemon": "^2.0.22",
    "supertest": "^6.3.4"
  },
  "jest": {
    "testEnvironment": "node",
    "testTimeout": 20000
  }
}
